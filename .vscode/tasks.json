{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "config-override.typ anlegen",
            "detail": "Erstellt config-override.typ aus der Vorlage, falls noch nicht vorhanden (läuft beim Öffnen des Ordners).",
            "type": "process",
            "command": "sh",
            "args": [
                "${workspaceFolder}/.vscode/scripts/init-config-override.sh"
            ],
            "windows": {
                "command": "powershell.exe",
                "args": [
                    "-NoProfile",
                    "-ExecutionPolicy",
                    "Bypass",
                    "-File",
                    "${workspaceFolder}/.vscode/scripts/init-config-override.ps1"
                ]
            },
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Arbeit als PDF exportieren",
            "detail": "Exportiert main.typ nach .export/<Datum> <Typ> <Vorname> <Nachname>.pdf",
            "type": "process",
            "command": "sh",
            "args": [
                "${workspaceFolder}/.vscode/scripts/export-pdf.sh"
            ],
            "windows": {
                "command": "powershell.exe",
                "args": [
                    "-NoProfile",
                    "-ExecutionPolicy",
                    "Bypass",
                    "-File",
                    "${workspaceFolder}/.vscode/scripts/export-pdf.ps1"
                ]
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        }
    ]
}
