{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Arbeit als PDF exportieren",
            "detail": "Exportiert main.typ nach .export/<Datum> <Typ> <Vorname> <Nachname>.pdf",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/.vscode/export-pdf.ps1"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        }
    ]
}
