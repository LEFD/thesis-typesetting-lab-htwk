{
    "Abbildung (figure mit flex-caption)": {
        "scope": "typst",
        "prefix": [
            "image",
            "abbildung",
            "bild"
        ],
        "description": "Fügt ein Bild als #figure mit kurzer und langer Bildunterschrift sowie Label ein",
        "body": [
            "#figure(",
            "  image(",
            "    \"/images/${1:placeholder.png}\",",
            "  ),",
            "  caption: flex-caption(",
            "    [${2:Bildunterschrift (lang)}],",
            "    [${3:Bildunterschrift im Abbildungsverzeichnis (kurz)}],",
            "  ),",
            ") <fig:${4:name-of-picture}>$0"
        ]
    }
}
